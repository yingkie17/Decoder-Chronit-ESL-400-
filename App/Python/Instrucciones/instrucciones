cat > /home/nancy/Escritorio/Chronit/setup.sh << 'EOF'
#!/bin/bash

# CHRONIT RACING SYSTEM - INSTALADOR PORTABLE
# Ejecutar una sola vez: chmod +x setup.sh && ./setup.sh

set -e

echo "========================================="
echo "🏁 CHRONIT RACING SYSTEM v6.0"
echo "========================================="
echo ""

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Verificar Docker
if ! command -v docker &> /dev/null; then
    echo -e "${RED}❌ Docker no está instalado${NC}"
    echo ""
    echo "📥 Instalar Docker ejecutando:"
    echo "   curl -fsSL https://get.docker.com | sudo sh"
    echo "   sudo usermod -aG docker \$USER"
    echo ""
    echo "Luego cierra sesión y vuelve a entrar, o ejecuta: newgrp docker"
    exit 1
fi

# Verificar Docker Compose
if ! docker compose version &> /dev/null; then
    echo -e "${YELLOW}⚠️ Docker Compose no disponible, instalando...${NC}"
    sudo apt update && sudo apt install -y docker-compose-plugin
fi

# Crear estructura de directorios
echo "📁 Creando estructura de directorios..."
mkdir -p App/Python/{data,templates,static}
mkdir -p infrastructure

# Verificar puerto USB
echo ""
echo "🔍 Detectando puerto serial..."
if [ -e /dev/ttyUSB0 ]; then
    SERIAL_PORT="/dev/ttyUSB0"
    echo -e "${GREEN}✅ Puerto encontrado: $SERIAL_PORT${NC}"
elif [ -e /dev/ttyACM0 ]; then
    SERIAL_PORT="/dev/ttyACM0"
    echo -e "${GREEN}✅ Puerto encontrado: $SERIAL_PORT${NC}"
else
    echo -e "${YELLOW}⚠️ No se detectó puerto USB${NC}"
    echo "   Conecta el ESL-400 y ejecuta: ls /dev/ttyUSB*"
    SERIAL_PORT="/dev/ttyUSB0"  # Default
fi

# Crear archivo .env
echo "SERIAL_PORT=$SERIAL_PORT" > infrastructure/.env
echo -e "${GREEN}✅ Configuración guardada${NC}"

# Crear script de inicio rápido
cat > /home/nancy/Escritorio/Chronit/start.sh << 'STARTSCRIPT'
