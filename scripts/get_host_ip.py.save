#!/usr/bin/env python3
import subprocess
import re
import sys

def get_wifi_ip():
    try:
        result = subprocess.run(['ip', 'addr', 'show', 'wlo1'], capture_output=True, text=True)
        match = re.search(r'inet (\d+\.\d+\.\d+\.\d+)/', result.stdout)
        if match:
            return match.group(1)
    except:
        pass
    
